---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/utils';
import FeatureCard from '../components/FeatureCard.astro';
import FAQItem from '../components/FAQItem.astro';
import WhitelistForm from '../components/WhitelistForm.astro';

const t = useTranslations('es');

// Example SVGs
const iconGeo = `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>`;
const iconProfile = `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>`;
const iconTrust = `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>`;
const iconTime = `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`;
---

<BaseLayout 
  title="Vontu | Banco del Tiempo Vecinal y Servicios Geolocalizados" 
  description="Intercambia favores con tus vecinos midiendo el valor en tiempo. Consigue ayuda, ofrece tus habilidades o adquiere créditos en Vontu."
>
  <!-- Hero Section -->
  <section class="py-20 md:py-32 px-4 max-w-5xl mx-auto text-center">
    <h1 class="text-5xl md:text-7xl font-black mb-8 leading-tight tracking-tight text-marron dark:text-crema">
      {t('hero.title')}
    </h1>
    <p class="text-xl md:text-2xl text-marron/80 dark:text-crema/80 mb-12 max-w-3xl mx-auto leading-relaxed">
      {t('hero.subtitle')}
    </p>
    <div class="flex justify-center">
      <a href="#whitelist" class="inline-flex items-center justify-center px-8 py-4 font-bold text-lg rounded-xl transition-all duration-300 transform hover:-translate-y-1 bg-terracota hover:bg-[#d94a27] text-crema dark:bg-turquesa dark:hover:bg-[#0c8282] dark:text-petroleo shadow-lg">
        {t('hero.cta')}
      </a>
    </div>
  </section>

  <!-- Features Section -->
  <section id="features" class="py-20 bg-white/50 dark:bg-petroleo/20">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-black text-center mb-16 text-marron dark:text-crema">{t('features.title')}</h2>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <FeatureCard 
          title={t('features.geo.title')} 
          description={t('features.geo.desc')} 
          icon={iconGeo}
        />
        <FeatureCard 
          title={t('features.profiles.title')} 
          description={t('features.profiles.desc')} 
          icon={iconProfile}
        />
        <FeatureCard 
          title={t('features.reviews.title')} 
          description={t('features.reviews.desc')} 
          icon={iconTrust}
        />
        <FeatureCard 
          title={t('features.credits.title')} 
          description={t('features.credits.desc')} 
          icon={iconTime}
        />
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section id="how-it-works" class="py-20 px-4 max-w-5xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-black text-center mb-16 text-marron dark:text-crema">{t('how.title')}</h2>
    
    <div class="grid md:grid-cols-3 gap-8">
      <div class="text-center relative bg-white dark:bg-black/20 p-8 rounded-2xl border-2 border-marron/20 dark:border-crema/20 shadow-sm h-full flex flex-col items-center hover:-translate-y-1 transition-transform">
        <div class="w-14 h-14 bg-terracota/10 dark:bg-turquesa/10 rounded-2xl flex items-center justify-center mx-auto mb-6 border border-terracota/20 dark:border-turquesa/20">
          <span class="text-2xl font-black text-terracota dark:text-turquesa">1</span>
        </div>
        <h3 class="text-xl font-bold mb-4 text-marron dark:text-crema">{t('how.step1.title')}</h3>
        <p class="text-marron/80 dark:text-crema/80 leading-relaxed">{t('how.step1.desc')}</p>
      </div>
      <div class="text-center relative bg-white dark:bg-black/20 p-8 rounded-2xl border-2 border-marron/20 dark:border-crema/20 shadow-sm h-full flex flex-col items-center hover:-translate-y-1 transition-transform">
        <div class="w-14 h-14 bg-terracota/10 dark:bg-turquesa/10 rounded-2xl flex items-center justify-center mx-auto mb-6 border border-terracota/20 dark:border-turquesa/20">
          <span class="text-2xl font-black text-terracota dark:text-turquesa">2</span>
        </div>
        <h3 class="text-xl font-bold mb-4 text-marron dark:text-crema">{t('how.step2.title')}</h3>
        <p class="text-marron/80 dark:text-crema/80 leading-relaxed">{t('how.step2.desc')}</p>
      </div>
      <div class="text-center relative bg-white dark:bg-black/20 p-8 rounded-2xl border-2 border-marron/20 dark:border-crema/20 shadow-sm h-full flex flex-col items-center hover:-translate-y-1 transition-transform">
        <div class="w-14 h-14 bg-terracota/10 dark:bg-turquesa/10 rounded-2xl flex items-center justify-center mx-auto mb-6 border border-terracota/20 dark:border-turquesa/20">
          <span class="text-2xl font-black text-terracota dark:text-turquesa">3</span>
        </div>
        <h3 class="text-xl font-bold mb-4 text-marron dark:text-crema">{t('how.step3.title')}</h3>
        <p class="text-marron/80 dark:text-crema/80 leading-relaxed">{t('how.step3.desc')}</p>
      </div>
    </div>
  </section>

  <!-- Whitelist Section -->
  <section id="whitelist" class="py-24 px-4 relative overflow-hidden bg-white/30 dark:bg-petroleo/30">
    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-terracota via-crema to-crema dark:from-turquesa dark:via-petroleo dark:to-petroleo"></div>
    <div class="relative z-10">
      <WhitelistForm />
    </div>
  </section>

  <!-- FAQs Section -->
  <section id="faq" class="py-20 px-4 max-w-3xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-black text-center mb-12 text-marron dark:text-crema">{t('faq.title')}</h2>
    <div class="bg-white dark:bg-black/20 rounded-2xl p-6 md:p-8 border-2 border-marron/20 dark:border-crema/20 shadow-sm">
      <FAQItem id="q1" question={t('faq.q1')} answer={t('faq.a1')} />
      <FAQItem id="q2" question={t('faq.q2')} answer={t('faq.a2')} />
      <FAQItem id="q3" question={t('faq.q3')} answer={t('faq.a3')} />
      <FAQItem id="q4" question={t('faq.q4')} answer={t('faq.a4')} />
    </div>
  </section>
</BaseLayout>
